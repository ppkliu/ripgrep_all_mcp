{
  "name": "rga-mcp-server",
  "version": "2.0.0",
  "description": "MCP server for ripgrep-all - Document search and text extraction across PDF, DOCX, EPUB, ZIP, and 20+ formats",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js",
    "lint": "eslint src --ext .ts",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "keywords": [
    "mcp",
    "ripgrep-all",
    "rga",
    "search",
    "pdf",
    "docx",
    "epub",
    "ocr",
    "agent",
    "docker"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "tsx": "^4.19.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0"
  }
}

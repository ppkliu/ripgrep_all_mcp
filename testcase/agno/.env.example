# Agno 測試 LLM 設定
# 複製此檔案為 .env 並填入實際值:
#   cp .env.example .env

# ============================================================
# 方式 A: OpenAI-compatible Local LLM (LM Studio, Ollama, vLLM)
# ============================================================
LLM_API_BASE=http://localhost:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL=openai/your-local-model

# ============================================================
# 方式 B: Anthropic API
# ============================================================
# ANTHROPIC_API_KEY=sk-ant-xxx
# LLM_MODEL=claude-sonnet-4-5

# ============================================================
# Document QA Workflow (document_qa_workflow.py)
# ============================================================
# LITELLM_MODEL=openai/your-model
# LITELLM_API_BASE=http://localhost:8000/v1
# LITELLM_API_KEY=sk-xxx
# MCP_URL=http://localhost:30003/mcp
# MAX_CONTEXT_TOKENS=32000
